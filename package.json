{
  "name": "personal-pokedex-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "npm run build",
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"wrangler dev --port 8787\"",
    "build": "vite build",
    "preview": "wrangler dev --local --port 8787",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:seed:local": "tsx scripts/seed-pokedex.ts --local",
    "db:seed:remote": "tsx scripts/seed-pokedex.ts --remote",
    "types:worker": "wrangler types worker-configuration.d.ts",
    "typecheck": "tsc --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"*.{js,json,md,ts,html}\" \".github/**/*.yml\" \"scripts/**/*.ts\" \"shared/**/*.ts\" \"src/**/*.{ts,tsx,css}\" \"test/**/*.ts\" \"worker/**/*.ts\"",
    "format:check": "prettier --check \"*.{js,json,md,ts,html}\" \".github/**/*.yml\" \"scripts/**/*.ts\" \"shared/**/*.ts\" \"src/**/*.{ts,tsx,css}\" \"test/**/*.ts\" \"worker/**/*.ts\"",
    "test": "npm run test:ui && npm run test:worker",
    "test:ui": "vitest run",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:watch": "vitest",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "hono": "^4.12.30",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
